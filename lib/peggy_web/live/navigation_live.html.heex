<div class="has-text-centered">
  <span class="icon-text is-size-3 has-text-weight-bold my-5">
    <span class="icon">
      <i class="fas fa-home"></i>
    </span>
    <span id="navigation-title"><%= @page_title %></span>
  </span>
</div>
<%= live_patch gettext("Farm List"), to: Routes.farm_index_path(@socket, :index), class: "button" %>
<%= live_patch gettext("Invite User"), to: Routes.invite_user_new_path(@socket, :new, @current_farm.id), class: "button" %>
