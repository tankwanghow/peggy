<section class="hero has-text-centered">
  <div class="container box">
    <p class="title"><%= gettext("Please Create a Farm.") %></p>
    <%= f = form_for @changeset, "#", id: "farm-form", phx_change: "validate", phx_submit: "save" %>
      <%= live_component PeggyWeb.FarmFieldsComponent, changeset: @changeset, f: f %>
      <%= submit gettext("Create Farm"), phx_disable_with: "Saving...", class: "button is-primary" %>
    </form>
  </div>
</section>
